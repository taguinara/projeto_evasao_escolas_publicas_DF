# Simplified .gitignore for a Python + Streamlit project on Windows (OneDrive)

# Byte-compiled / caches
__pycache__/
*.py[cod]
*.pyc

# Virtual environments
venv/
env/
.venv/

# Environment variables / secrets
.env
.env.*

# IDEs / editor
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/

# Test / typecheck caches
.pytest_cache/
.mypy_cache/

# Streamlit secrets
.streamlit/secrets.toml

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Data (ignore large raw/processed files by default)
data/raw/
data/processed/

# Logs and databases
*.log
*.sqlite3
*.db

# Misc
*.tmp
*.swp

# To keep a generated file under version control, add a negation rule, e.g.:
#  !data/processed/dashboard_evasao.csv
