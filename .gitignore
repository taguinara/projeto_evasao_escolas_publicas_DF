# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/
__pypackages__/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
coverage.xml

# Jupyter
.ipynb_checkpoints/

# Editor directories and files
.vscode/
.idea/
*.suo
*.user
*.pyproj

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs and databases
*.log
*.sqlite3
*.db

# Secrets / environment
.env
.env.*
secrets.toml
*.pem
*.key

# Airflow local DB and logs (if running locally)
airflow.cfg
airflow.db
logs/

# Data files (raw and processed) - usually large or generated
data/raw/
data/processed/

# PyInstaller
*.manifest
*.spec

# IDE / tooling
.mypy_cache/
.pytest_cache/

# Temporary files
*.swp
*~

# OneDrive / Windows paths (ignore sync conflict files)
~$*
*.lnk

# End of .gitignore
